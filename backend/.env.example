
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1

MONGO_URI=mongodb://127.0.0.1:27017/smart_finance_tracker

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=
